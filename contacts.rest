# =============================================
# Contacts API - REST Client Test File
# =============================================

@BASE_URL = http://localhost:3000
# @BASE_URL = https://cse341-vwck.onrender.com

### Root
GET {{BASE_URL}}/

###

### Swagger Docs
GET {{BASE_URL}}/api-docs

###

### GET all contacts
GET {{BASE_URL}}/contacts

###

### GET a single contact by ID
GET {{BASE_URL}}/contacts/REPLACE_WITH_REAL_ID

###

### POST - Create contact 1
POST {{BASE_URL}}/contacts
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@example.com",
  "favoriteColor": "Purple",
  "birthday": "1995-03-22"
}

###

### POST - Create contact 2
POST {{BASE_URL}}/contacts
Content-Type: application/json

{
  "firstName": "Brian",
  "lastName": "Mwangi",
  "email": "brian.mwangi@example.com",
  "favoriteColor": "Orange",
  "birthday": "1988-07-10"
}

###

### PUT - Update a contact
PUT {{BASE_URL}}/contacts/REPLACE_WITH_REAL_ID
Content-Type: application/json

{
  "favoriteColor": "Teal",
  "email": "updated.email@example.com"
}

###

### DELETE - Delete a contact
DELETE {{BASE_URL}}/contacts/REPLACE_WITH_REAL_ID
